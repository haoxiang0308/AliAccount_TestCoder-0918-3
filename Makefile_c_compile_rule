# Makefile for compiling a C program

# Compiler
CC = gcc

# Compiler flags
CFLAGS = -Wall -g

# Target executable name
TARGET = program

# Source files
SOURCES = main.c

# Default rule to build the target
$(TARGET): $(SOURCES)
	$(CC) $(CFLAGS) -o $(TARGET) $(SOURCES)

# Clean rule to remove compiled files
clean:
	rm -f $(TARGET)

# Phony targets
.PHONY: clean