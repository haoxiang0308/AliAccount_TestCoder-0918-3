```gitignore
# Temporary files
*.tmp
*.swp
*.swo

# Logs
*.log

# Editor/IDE files
.vscode/
.idea/

# Environment files
.env
.env.local
*.env.*

# Coverage reports
coverage/
htmlcov/
.coverage

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/
.ENV

# Build artifacts
dist/
build/
*.out
*.exe
*.dll
*.so
*.a
*.obj

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compression files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst

# System files
.DS_Store
Thumbs.db
```