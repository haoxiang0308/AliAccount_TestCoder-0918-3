```gitignore
# Compiled and build artifacts
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
pip-wheel-metadata/

# Logs and temp files
*.log
*.tmp
*.swp

# Environment
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Coverage
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
.hypothesis/

# OS
.DS_Store
Thumbs.db
```