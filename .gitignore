*.tar.xz
*.tar.zst

# Julia standard library test packages
**/test/test_packages/

# Julia test depot
**/test/depot/

# Julia build/test artifacts
**/test/**/*.jl
**/test/**/Manifest.toml
**/test/**/Project.toml

# Julia docs and generated files
**/docs/make.jl
**/docs/Project.toml
**/docs/src/

# Julia extension and package files
**/ext/
**/deps/
**/gen/

# Julia artifacts and registry files
**/Artifacts.toml
**/StdlibArtifacts.toml
**/LazyArtifacts/

# Julia build system files
**/Makefile
**/CMakeLists.txt
**/build/
**/dist/

# Julia temporary and log files
**/*.tmp
**/*.log
**/test/**/test_*.jl
**/test/**/runtests.jl
```