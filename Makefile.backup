# Makefile for compilation and cleanup

# Compiler settings
CC = gcc
CFLAGS = -Wall -g
TARGET = program
SOURCES = $(wildcard *.c)
OBJECTS = $(SOURCES:.c=.o)

# Default target
all: $(TARGET)

# Linking
$(TARGET): $(OBJECTS)
	$(CC) $(OBJECTS) -o $(TARGET)

# Compilation
%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@

# Cleanup
clean:
	rm -f $(OBJECTS) $(TARGET)

# Phony targets
.PHONY: all clean